# Supabase (required for auth + workspace data)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — required in production for plan limits and usage tracking.
# Without it, scan/product caps cannot be enforced server-side.
SUPABASE_SERVICE_ROLE_KEY=

# Rate limits (per user, per minute unless noted)
ANALYSIS_RATE_LIMIT=20
COPILOT_RATE_LIMIT=30

# Optional: Upstash Redis for distributed rate limiting across serverless instances.
# Without these, in-memory rate limits are used (reset on cold starts).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Dodo Payments billing
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_RETURN_URL=http://localhost:3002/settings?billing=success
DODO_GROWTH_MONTHLY_PRODUCT_ID=
DODO_GROWTH_ANNUAL_PRODUCT_ID=
DODO_TEAM_MONTHLY_PRODUCT_ID=
DODO_TEAM_ANNUAL_PRODUCT_ID=